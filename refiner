def _hud_integrate(db, port):
    """修改 common_config_claude 的 statusLine 命令，包裹 refiner HUD"""
    cursor = db.cursor()
    cursor.execute("SELECT value FROM settings WHERE key='common_config_claude'")
    row = cursor.fetchone()
    if not row:
        return False
    common = json.loads(row[0])

    # 备份原始 statusLine
    if '__refiner_statusline_original' not in common:
        common['__refiner_statusline_original'] = json.dumps(common.get('statusLine', {}))

    old_cmd = common.get('statusLine', {}).get('command', '')
    if not old_cmd:
        return False

    # 已包裹则跳过
    if '/tmp/refiner-status.txt' in old_cmd:
        return False

    # 找到 exec "$NODE" "$INDEX" 并替换
    import re
    match = re.search(r'exec\s+("[^"]+")\s+("[^"]+")', old_cmd)
    if not match:
        return False

    node_path = match.group(1)
    hud_index = match.group(2)

    # 替换 exec 为：捕获 stdin → pipe 到 node → prepend refiner → 输出
    inner = old_cmd[len("bash -c '"):-1]
    new_suffix = (
        f'STDIN=$(cat); '
        f'OUT=$(echo "$STDIN" | {node_path} {hud_index} 2>/dev/null); '
        f'RF=$(head -c 80 /tmp/refiner-status.txt 2>/dev/null | tr "\\n" " "); '
        f'[ -n "$RF" ] && echo "✎ $RF"; '
        f'echo "$OUT"'
    )
    new_inner = inner.replace(f'exec {node_path} {hud_index}', new_suffix)

    new_cmd = f"bash -c '{new_inner}'"
    common['statusLine']['command'] = new_cmd
    cursor.execute(
        "UPDATE settings SET value = ? WHERE key = 'common_config_claude'",
        (json.dumps(common, ensure_ascii=False),),
    )
    db.commit()

    # 同步到 settings.json
    _sync_settings_json(db)

    return True


def _hud_restore(db):
    """还原 statusLine 命令"""
    cursor = db.cursor()
    cursor.execute("SELECT value FROM settings WHERE key='common_config_claude'")
    row = cursor.fetchone()
    if not row:
        return False
    common = json.loads(row[0])

    backup = common.pop('__refiner_statusline_original', None)
    if not backup:
        return False

    try:
        original_sl = json.loads(backup)
    except (json.JSONDecodeError, TypeError):
        original_sl = {"type": "command", "command": backup}

    common['statusLine'] = original_sl
    cursor.execute(
        "UPDATE settings SET value = ? WHERE key = 'common_config_claude'",
        (json.dumps(common, ensure_ascii=False),),
    )
    db.commit()

    # 同步到 settings.json
    _sync_settings_json(db)

    return True


def _sync_settings_json(db):
    """将当前 provider 的 endpoint 同步到 ~/.claude/settings.json"""
    cursor = db.cursor()
    cursor.execute(
        "SELECT settings_config FROM providers WHERE app_type='claude' AND is_current=1"
    )
    row = cursor.fetchone()
    if not row:
        return

    provider_cfg = json.loads(row[0])
    provider_env = provider_cfg.get("env", {})

    settings_path = Path.home() / ".claude" / "settings.json"
    try:
        with open(settings_path) as f:
            settings = json.load(f)
    except Exception:
        return

    # 只更新 env 中的请求端点
    for key in ["ANTHROPIC_BASE_URL", "ANTHROPIC_AUTH_TOKEN",
                "ANTHROPIC_DEFAULT_HAIKU_MODEL", "ANTHROPIC_DEFAULT_SONNET_MODEL",
                "ANTHROPIC_DEFAULT_OPUS_MODEL", "ANTHROPIC_MODEL"]:
        if key in provider_env:
            settings.setdefault("env", {})[key] = provider_env[key]

    with open(settings_path, "w") as f:
        json.dump(settings, f, indent=2, ensure_ascii=False)


def cmd_setup(config, args):
    """一键接入：遍历 ccswitch 所有 provider，endpoint 指向 refiner"""
    port = getattr(args, "port", 18888)
    proxy_prefix = f"http://localhost:{port}/proxy/"

    if not CCSWITCH_DB.exists():
        print(f"ccswitch 数据库未找到: {CCSWITCH_DB}")
        sys.exit(1)

    db = sqlite3.connect(str(CCSWITCH_DB))
    db.row_factory = sqlite3.Row
    cursor = db.cursor()

    # 获取所有 provider
    cursor.execute("SELECT id, app_type, name, settings_config FROM providers")
    providers = cursor.fetchall()

    updated = 0
    skipped = 0

    for row in providers:
        pid = row["id"]
        name = row["name"]
        app_type = row["app_type"]

        try:
            cfg = json.loads(row["settings_config"])
        except (json.JSONDecodeError, TypeError):
            print(f"  ⚠ {name} ({app_type}): 配置解析失败，跳过")
            skipped += 1
            continue

        # 从 env 中找到 base_url / endpoint
        env = cfg.get("env", {})
        current_url = env.get("ANTHROPIC_BASE_URL", "")
        if not current_url:
            # 可能是个 OpenAI 风格的 provider，试试 OPENAI_BASE_URL
            current_url = env.get("OPENAI_BASE_URL", "") or env.get("BASE_URL", "")

        if not current_url:
            print(f"  - {name} ({app_type}): 无已知 endpoint，跳过")
            skipped += 1
            continue

        # 跳过 localhost（本地模型，不需要精炼），但放过已指向 refiner 的
        if ("localhost" in current_url or "127.0.0.1" in current_url) and "/proxy/" not in current_url:
            print(f"  - {name} ({app_type}): 本地端点，跳过")
            skipped += 1
            continue

        if "/proxy/" in current_url:
            print(f"  - {name} ({app_type}): 已接入，跳过")
            skipped += 1
            continue

        # 备份原始 URL
        if "__refiner_original_url" not in cfg:
            cfg["__refiner_original_url"] = current_url

        # 计算 proxy path
        parsed = current_url.replace("https://", "").replace("http://", "")
        # 去掉可能的末尾斜杠
        parsed = parsed.rstrip("/")
        proxy_endpoint = proxy_prefix + parsed

        env["ANTHROPIC_BASE_URL"] = proxy_endpoint
        cfg["env"] = env
        cfg["settings_config"] = json.dumps(cfg, ensure_ascii=False)

        # 写回 DB
        cursor.execute(
            "UPDATE providers SET settings_config = ? WHERE id = ?",
            (json.dumps(cfg, ensure_ascii=False), pid),
        )
        print(f"  ✓ {name} ({app_type}): {current_url} → {proxy_endpoint}")
        updated += 1

    db.commit()
    # HUD 集成（在 db.close() 前）
    try:
        if _hud_integrate(db, port):
            print(f"  ✓ HUD 已集成")
    except Exception as e:
        print(f"  - HUD 配置异常: {e}")

    # 同步到 ~/.claude/settings.json（Claude Code 实际读的是这个文件）
    _sync_settings_json(db)

    db.close()

    # 重启 ccswitch 使 endpoint 变更生效
    if updated > 0:
        subprocess.run(["pkill", "-f", "cc-switch"], capture_output=True, timeout=5)
        print(f"  ✓ ccswitch 已重启")

    print(f"\n完成: {updated} 个 provider 已接入, {skipped} 个跳过")
    print(f"\nrefiner 端口: {port}")
    print(f"还原命令: refiner teardown")


def cmd_teardown(config, args):
    """一键还原：恢复所有 provider 的原始 endpoint"""
    if not CCSWITCH_DB.exists():
        print(f"ccswitch 数据库未找到: {CCSWITCH_DB}")
        sys.exit(1)

    db = sqlite3.connect(str(CCSWITCH_DB))
    db.row_factory = sqlite3.Row
    cursor = db.cursor()

    cursor.execute("SELECT id, app_type, name, settings_config FROM providers")
    providers = cursor.fetchall()

    restored = 0

    for row in providers:
        pid = row["id"]
        name = row["name"]
        app_type = row["app_type"]

        try:
            cfg = json.loads(row["settings_config"])
        except (json.JSONDecodeError, TypeError):
            continue

        original = cfg.pop("__refiner_original_url", None)
        if original is None:
            continue

        env = cfg.get("env", {})
        env["ANTHROPIC_BASE_URL"] = original
        cfg["env"] = env

        cursor.execute(
            "UPDATE providers SET settings_config = ? WHERE id = ?",
            (json.dumps(cfg, ensure_ascii=False), pid),
        )
        print(f"  ✓ {name} ({app_type}): 已还原 → {original}")
        restored += 1

    db.commit()

    # 还原 HUD
    if _hud_restore(db):
        print(f"  ✓ HUD 已还原")

    # 同步 settings.json
    _sync_settings_json(db)

    db.close()

    print(f"\n完成: {restored} 个 provider 已还原")


