def get_docker_container():
    """找到 llama.cpp Docker 容器"""
    try:
        result = subprocess.run(
            ["docker", "ps", "--format", "{{.ID}}\t{{.Names}}\t{{.Image}}",
             "--filter", "publish=8080"],
            capture_output=True, text=True, timeout=5
        )
        for line in result.stdout.strip().splitlines():
            if line:
                cid, name, image = line.split("\t")
                if "llama" in image.lower() or "llama" in name.lower():
                    return cid, name, image
    except Exception:
        pass
    return None, None, None


def get_container_config(container_id):
    """获取容器的挂载信息和当前模型路径"""
    try:
        result = subprocess.run(
            ["docker", "inspect", container_id],
            capture_output=True, text=True, timeout=5
        )
        info = json.loads(result.stdout)[0]
        mounts = {}
        for m in info.get("Mounts", []):
            mounts[m["Destination"]] = m["Source"]
        cmd = info["Config"]["Cmd"] or []
        current_model = None
        for i, arg in enumerate(cmd):
            if arg == "--model" and i + 1 < len(cmd):
                current_model = cmd[i + 1]
        return mounts, current_model
    except Exception:
        return {}, None


def list_models(models_dir):
    """列出所有 gguf 文件"""
    path = Path(models_dir)
    if not path.exists():
        return []
    models = sorted(path.glob("*.gguf"))
    return models


def check_health(endpoint_base="http://localhost:8080", timeout=60):
    """等待本地模型就绪"""
    deadline = time.time() + timeout
    while time.time() < deadline:
        try:
            import httpx
            resp = httpx.get(f"{endpoint_base}/health", timeout=3, proxy=None, trust_env=False)
            if resp.status_code == 200:
                return True
        except Exception:
            pass
        time.sleep(1)
    return False


