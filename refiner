# 上游 API 自动检测映射
UPSTREAM_RULES = [
    (r"^ark-", "https://ark.cn-beijing.volces.com/api/coding"),
    (r"^sk-.*dashscope", "https://dashscope.aliyuncs.com/apps/anthropic"),
    (r"^sk-", "https://api.deepseek.com/anthropic"),
]

