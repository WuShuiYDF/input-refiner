def refine(text, config):
    """调用本地模型精炼文本"""
    endpoint = config["refiner"]["endpoint"]
    prompt = config["prompt"]
    timeout = config["refiner"]["timeout"]
    max_tokens = config["refiner"]["max_tokens"]

    try:
        import httpx
        completions_url = endpoint.rsplit("/chat/completions", 1)[0] + "/completions"
        completion_prompt = f"{prompt}\n\n输入：{text}\n\n输出："

        resp = httpx.post(
            completions_url,
            json={
                "prompt": completion_prompt,
                "max_tokens": max_tokens,
                "temperature": 0.1,
                "stop": ["\n\n", "。\n"],
            },
            timeout=timeout + 2,
            proxy=None, trust_env=False,
        )
        if resp.status_code == 200:
            body = resp.json()
            result = body["choices"][0].get("text", "").strip()
            if result and result != text:
                return result
    except Exception as e:
        logging.getLogger("refiner").warning("精炼失败: %s", e)

    return text


def log_refinement(original, refined, config):
    """写日志"""
    path = Path(config["log"]["path"])
    max_lines = config["log"]["max_lines"]
    path.parent.mkdir(parents=True, exist_ok=True)

    entry = (
        f"[{time.strftime('%H:%M:%S')}] "
        f"原文: {original[:200]}\n"
        f"      精炼: {refined[:200]}\n"
        f"      节省: {max(0, len(original) - len(refined))} 字符\n"
    )
    lines = []
    if path.exists():
        lines = path.read_text(encoding="utf-8").splitlines()
    lines.append(entry)
    if len(lines) > max_lines:
        lines = lines[-max_lines:]
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def update_hud(refined, config):
    if not config["hud"]["enabled"]:
        return
    max_len = config["hud"]["max_display_len"]
    display = refined[:max_len] if len(refined) > max_len else refined
    display = display.replace("\n", " ")
    try:
        Path(config["hud"]["status_file"]).write_text(display, encoding="utf-8")
    except Exception:
        pass


def parse_upstream(path):
    """从 path 提取上游 URL

    /proxy/api.deepseek.com/anthropic/v1/messages
      → upstream: https://api.deepseek.com/anthropic
      → api_path: /v1/messages
    """
    m = re.match(r"^/proxy/([^/]+(?:/[^/]+)*?)(?=/v[0-9]+/)", path)
    if not m:
        return None, path
    host_and_base = m.group(1)
    upstream = f"https://{host_and_base}"
    prefix = f"/proxy/{host_and_base}"
    api_path = path[len(prefix):] if path.startswith(prefix) else path
    return upstream, api_path or "/"


def _should_skip_refinement(content, config):
    """跳过非用户输入：系统指令、agent prompt、过长的上下文"""
    # 太长 = 非用户输入（agent 指令 / 上下文片段）
    if len(content) > 1000:
        return True
    # 系统模式
    skip_patterns = [
        "SUGGESTION MODE", "[SUGGESTION", "You are a",
        "Base directory for this skill",
    ]
    for p in skip_patterns:
        if p.lower() in content.lower():
            return True
    return False


class RefinerHandler(BaseHTTPRequestHandler):
    config = None
    logger = None

    def log_message(self, fmt, *args):
        self.logger.debug("HTTP %s", fmt % args)

    def do_POST(self):
        config = self.config
        logger = self.logger

        # 解析上游
        upstream, api_path = parse_upstream(self.path)
        if upstream is None:
            self.send_response(400)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(b'{"error":"invalid proxy path"}')
            return

        target_url = f"{upstream}{api_path}"
        logger.debug("上游: %s", target_url)

        # 读请求体
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length)

        try:
            data = json.loads(body)
        except json.JSONDecodeError:
            self._proxy(body, target_url, False)
            return

        # scope 检查
        apps_scope = config["scope"].get("apps", [])
        if apps_scope:
            ua = self.headers.get("User-Agent", "")
            if not any(a.lower() in ua.lower() for a in apps_scope):
                self._proxy(body, target_url, False)
                return

        # 精炼最后一条 user message
        messages = data.get("messages", [])
        refined = False
        for i in range(len(messages) - 1, -1, -1):
            if messages[i].get("role") == "user":
                content = messages[i].get("content", "")
                if not isinstance(content, str) or not content.strip():
                    break

                # 跳过非用户输入（系统指令、agent prompt 等）
                if _should_skip_refinement(content, config):
                    logger.info("跳过精炼（非用户输入，%d 字符）", len(content))
                    break

                skip_prefix = config["skip_prefix"]
                if skip_prefix and content.startswith(skip_prefix):
                    messages[i]["content"] = content[len(skip_prefix):].lstrip()
                    logger.info("跳过精炼 (%s)", skip_prefix)
                else:
                    logger.info("精炼中... (%d 字符)", len(content))
                    start = time.time()
                    refined_text = refine(content, config)
                    elapsed = time.time() - start
                    logger.info("精炼完成 (%.1fs): %d → %d 字符",
                                elapsed, len(content), len(refined_text))
                    log_refinement(content, refined_text, config)
                    # 始终更新 HUD 和消息（即使文本未变）
                    update_hud(refined_text, config)
                    messages[i]["content"] = refined_text
                    refined = True
                break

        if refined:
            data["messages"] = messages
            body = json.dumps(data).encode("utf-8")

        self._proxy(body, target_url, refined)

    def _proxy(self, body, target_url, was_refined=False):
        config = self.config
        logger = self.logger

        # 构造请求头
        fwd_headers = {}
        skip_hdrs = {"host", "connection", "transfer-encoding", "keep-alive",
                      "proxy-connection", "proxy-authenticate", "proxy-authorization",
                      "te", "trailer", "upgrade"}
        for k, v in self.headers.items():
            if k.lower() not in skip_hdrs:
                fwd_headers[k] = v

        # 修正 Content-Length
        for k in list(fwd_headers.keys()):
            if k.lower() == "content-length":
                del fwd_headers[k]
        fwd_headers["Content-Length"] = str(len(body))

        try:
            import httpx

            with httpx.stream(
                "POST", target_url,
                headers=fwd_headers,
                content=body,
                timeout=config["refiner"]["timeout"] + 120,
                proxy=None, trust_env=False,
            ) as resp:
                self.send_response(resp.status_code)
                for k, v in resp.headers.items():
                    if k.lower() not in skip_hdrs:
                        self.send_header(k, v)
                if was_refined:
                    self.send_header("X-Refiner-Processed", "1")
                self.end_headers()
                for chunk in resp.iter_bytes(8192):
                    try:
                        self.wfile.write(chunk)
                        self.wfile.flush()
                    except (BrokenPipeError, ConnectionResetError):
                        break

        except Exception as e:
            logger.error("上游请求失败: %s", e)
            try:
                self.send_response(502)
                self.send_header("Content-Type", "application/json")
                self.end_headers()
                self.wfile.write(
                    json.dumps({"error": f"input-refiner: upstream unreachable: {e}"}).encode()
                )
            except Exception:
                pass

    def do_GET(self):
        if self.path == "/health":
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(b'{"status":"ok","service":"input-refiner"}')
        else:
            self.send_response(404)
            self.end_headers()

    def do_OPTIONS(self):
        self.send_response(200)
        self.send_header("Allow", "POST, GET, OPTIONS")
        self.end_headers()


