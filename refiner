def cmd_serve(config, args):
    """启动 HTTP 代理服务"""
    port = getattr(args, "port", 18888)
    host = getattr(args, "bind", "127.0.0.1")

    # 配置日志
    logger = logging.getLogger("refiner")
    logger.setLevel(logging.DEBUG if getattr(args, "verbose", False) else logging.INFO)
    handler = logging.StreamHandler()
    handler.setFormatter(logging.Formatter(
        "%(asctime)s [%(levelname)s] %(message)s", datefmt="%H:%M:%S"
    ))
    logger.handlers = [handler]

    # 注入到 handler 类
    RefinerHandler.config = config
    RefinerHandler.logger = logger

    server = HTTPServer((host, port), RefinerHandler)

    def shutdown(sig, frame):
        logger.info("正在关闭...")
        server.shutdown()

    signal.signal(signal.SIGINT, shutdown)
    signal.signal(signal.SIGTERM, shutdown)

    logger.info("input-refiner 已启动 → http://%s:%d", host, port)
    logger.info("精炼端点: %s", config["refiner"]["endpoint"])
    logger.info("上游模式: %s", config.get("upstream", "auto"))
    logger.info("跳过前缀: %s", config.get("skip_prefix", "!!!"))
    logger.info("")
    logger.info("ccswitch provider endpoint 请设置为: http://%s:%d/v1/messages", host, port)
    logger.info("健康检查: http://%s:%d/health", host, port)

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()
        logger.info("已停止")


def cmd_models(config, args):
    """列出所有可用模型"""
    models_dir = config["refiner"]["models_dir"]
    models = list_models(models_dir)

    if not models:
        print(f"在 {models_dir} 下未找到 .gguf 文件")
        return

    cid = get_docker_container()[0] or ""
    _, current_model_path = get_container_config(cid) if cid else ({}, None)
    current_name = Path(current_model_path).stem if current_model_path else None

    print(f"可用模型 ({models_dir}):\n")
    for i, m in enumerate(models, 1):
        size_gb = m.stat().st_size / (1024 ** 3)
        marker = " ← 当前" if (current_model_path and m.name in str(current_model_path)) else ""
        print(f"  {i}. {m.name}  ({size_gb:.1f} GB){marker}")


def cmd_switch(config, args):
    """切换模型 — 重启 Docker 容器"""
    target = args.name
    models_dir = config["refiner"]["models_dir"]
    models = list_models(models_dir)

    match = None
    for m in models:
        if target in m.name or target == m.stem:
            match = m
            break

    if match is None:
        print(f"未找到匹配 '{target}' 的模型。可用模型:")
        for m in models:
            print(f"  {m.stem}")
        sys.exit(1)

    cid, cname, cimage = get_docker_container()
    if cid is None:
        print("未找到运行中的 llama.cpp Docker 容器")
        print(f"请手动启动并指定模型: --model /models/{match.name}")
        sys.exit(1)

    # 获取当前容器的完整命令
    result = subprocess.run(
        ["docker", "inspect", cid], capture_output=True, text=True, timeout=5
    )
    info = json.loads(result.stdout)[0]
    entrypoint = info["Config"].get("Entrypoint") or []
    old_cmd = info["Config"].get("Cmd") or []
    full_cmd = entrypoint + old_cmd

    # 替换 --model 参数
    new_cmd = []
    skip = False
    for arg in full_cmd:
        if skip:
            skip = False
            continue
        if arg == "--model":
            new_cmd.extend(["--model", f"/models/{match.name}"])
            skip = True
        else:
            new_cmd.append(arg)

    # 提取挂载和端口映射用于重建
    mounts_args = []
    for mnt in info.get("Mounts", []):
        mounts_args.extend(["-v", f"{mnt['Source']}:{mnt['Destination']}"])

    port_args = []
    for container_port, bindings in info.get("HostConfig", {}).get("PortBindings", {}).items():
        for b in (bindings or []):
            port_args.extend(["-p", f"{b['HostPort']}:{container_port.split('/')[0]}"])

    env_args = []
    for e in info["Config"].get("Env", []):
        env_args.extend(["-e", e])

    gpu_args = []
    for dev in info.get("HostConfig", {}).get("DeviceRequests", []):
        if dev.get("Driver") == "nvidia":
            gpu_args = ["--gpus", "all"]
            break

    # 先 rm 旧容器，再启动新的
    print(f"停止并删除旧容器 {cname}...")
    subprocess.run(["docker", "stop", cid], capture_output=True, timeout=30)
    subprocess.run(["docker", "rm", cid], capture_output=True, timeout=10)

    run_cmd = ["docker", "run", "-d", "--name", cname] + gpu_args + port_args + mounts_args + env_args + [cimage] + new_cmd

    print(f"启动新容器 {cname}，模型: {match.name}...")
    result = subprocess.run(run_cmd, capture_output=True, text=True, timeout=30)
    if result.returncode != 0:
        print(f"启动失败:\n{result.stderr}")
        sys.exit(1)

    new_cid = result.stdout.strip()[:12]
    print(f"容器 {new_cid} 已启动")

    # 等待就绪
    print("等待模型加载", end="", flush=True)
    if check_health(timeout=120):
        print(" ✓")
        print(f"已切换到 {match.stem}")
    else:
        print(f" ⚠ 超时，请检查: docker logs {cname}")


def cmd_status(config, args):
    """查看当前状态"""
    cid, cname, cimage = get_docker_container()

    print("input-refiner 状态\n")
    print(f"{'本地容器:':<16} {cname or '未运行'} ({cimage or '-'})")
    print(f"{'容器 ID:':<16} {cid or '-'}")

    if cid:
        _, current = get_container_config(cid)
        print(f"{'当前模型:':<16} {Path(current).stem if current else '未知'}")

    # 健康检查
    healthy = check_health(timeout=3)
    print(f"{'健康状态:':<16} {'✓ 正常' if healthy else '✗ 不可达'}")

    # refiner 代理状态
    try:
        from httpx import get as httpx_get
        resp = httpx_get("http://localhost:18888/health", timeout=2, proxy=None, trust_env=False)
        print(f"{'refiner 代理:':<16} {'✓ 运行中' if resp.status_code == 200 else '✗ 异常'}")
    except Exception:
        print(f"{'refiner 代理:':<16} {'✗ 未运行'}")


def main():
    parser = argparse.ArgumentParser(description="input-refiner — 本地模型输入精炼代理")
    sub = parser.add_subparsers(dest="command")

    # serve
    p_serve = sub.add_parser("serve", help="启动 HTTP 代理")
    p_serve.add_argument("--port", type=int, default=18888, help="监听端口 (默认 18888)")
    p_serve.add_argument("--bind", default="127.0.0.1", help="绑定地址 (默认 127.0.0.1)")
    p_serve.add_argument("-v", "--verbose", action="store_true", help="调试模式")

    # models
    sub.add_parser("models", help="列出可用 gguf 模型")

    # switch
    p_switch = sub.add_parser("switch", help="切换模型")
    p_switch.add_argument("name", help="模型名 (模糊匹配)")

    # status
    sub.add_parser("status", help="查看当前状态")

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    config = load_config()

    if args.command == "serve":
        cmd_serve(config, args)
    elif args.command == "models":
        cmd_models(config, args)
    elif args.command == "switch":
        cmd_switch(config, args)
    elif args.command == "status":
        cmd_status(config, args)


if __name__ == "__main__":
    main()
