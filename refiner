# 配置
# ────────────────────────────────────────

def find_config():
    """搜索 config.yaml，优先级: 当前目录 > ~/.config/input-refiner > ~/input-refiner > 内置"""
    paths = [
        Path("config.yaml"),
        Path.home() / ".config" / "input-refiner" / "config.yaml",
        Path(__file__).resolve().parent / "config.yaml",
    ]
    for p in paths:
        if p.exists():
            return p
    return None


def load_config():
    """加载配置，文件缺失时返回内置默认值"""
    cfg_path = find_config()
    if cfg_path is None:
        return dict(DEFAULT_CONFIG)

    try:
        import yaml
    except ImportError:
        return dict(DEFAULT_CONFIG)

    with open(cfg_path) as f:
        user = yaml.safe_load(f) or {}

    # 深度合并
    cfg = dict(DEFAULT_CONFIG)
    for section in cfg:
        if section in user and isinstance(user[section], dict):
            cfg[section] = {**cfg[section], **user[section]}
        elif section in user:
            cfg[section] = user[section]
    return cfg


def detect_upstream(api_key, upstream_config):
    """解析上游 URL — 优先查 map 表（API key 前缀匹配），兜底 default"""
    if isinstance(upstream_config, str):
        if upstream_config and upstream_config != "auto":
            return upstream_config.rstrip("/")
    elif isinstance(upstream_config, dict):
        api_map = upstream_config.get("map", {})
        for prefix, url in api_map.items():
            if (api_key or "").startswith(prefix):
                return url.rstrip("/")
        default = upstream_config.get("default", "")
        if default:
            return default.rstrip("/")

    # 最终兜底：旧式前缀匹配
    for pattern, url in UPSTREAM_RULES:
        if re.match(pattern, api_key or ""):
            return url
    return "https://api.deepseek.com/anthropic"


